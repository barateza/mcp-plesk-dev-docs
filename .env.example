# ============================================================
# mcp-plesk-unified environment configuration
# Copy this file to .env and fill in your values.
# ============================================================


# ------------------------------------------------------------
# MODEL PROFILE
# Controls the RAM/VRAM vs quality trade-off.
#
# Options:
#   local   ~130 MB  snowflake/snowflake-arctic-embed-s + ms-marco-MiniLM-L-6-v2
#           Ideal for M1/M2 MacBook Air or any memory-constrained host.
#
#   pro     ~500 MB  Alibaba-NLP/gte-modernbert-base + ms-marco-MiniLM-L-6-v2
#           Default profile. State-of-the-art English retrieval.
#           Balanced option for any machine with 4+ GB free RAM.
#
#   sandbox ~1.3 GB (5-bit)  Alibaba-NLP/gte-large-en-v1.5 + BAAI/bge-reranker-base + TurboQuant
#           Experimental research profile using TurboQuant quantization.
#           Ultra-low latency with a massive English-only model (1024d).
#
# ⚠️  If you change between profiles with different embed_dim values
#     (local=384, pro=768, sandbox=1024), delete storage/lancedb and
#     run refresh_knowledge to rebuild the index.
# ------------------------------------------------------------
PLESK_MODEL_PROFILE=pro


# ------------------------------------------------------------
# PER-COMPONENT OVERRIDES (optional)
# These take precedence over whatever the profile sets.
# Only set these if you want a custom combination.
# ------------------------------------------------------------

# Override the embedding model name (HuggingFace model ID)
# PLESK_EMBED_MODEL=BAAI/bge-small-en-v1.5

# Override the embedding vector dimension.
# Required if PLESK_EMBED_MODEL is set to a model whose dim
# differs from the profile default.
# PLESK_EMBED_DIM=384

# Override the reranker model name (must be a CrossEncoder-compatible model)
# PLESK_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Set to false to disable reranking entirely (faster, slightly lower quality)
# PLESK_RERANKER_ENABLED=true


# ------------------------------------------------------------
# DEVICE
# Override automatic GPU detection.
# Options: cuda | mps | cpu
# Leave commented out to let the server detect automatically.
# ------------------------------------------------------------
# FORCE_DEVICE=cpu


# ------------------------------------------------------------
# INDEXING BATCH SIZE
# Controls how many text chunks are sent to the embedding model at once.
# If unset, defaults dynamically: 1000 on CUDA (Windows/Linux) and 64 on MPS/CPU (Mac).
# ------------------------------------------------------------
# PLESK_INDEXING_BATCH_SIZE=64


# ------------------------------------------------------------
# DAEMON STARTUP
# Enable background warmup after process start (daemon mode).
# Keeps startup responsive while preloading models and table.
# ------------------------------------------------------------
# PLESK_DAEMON_AUTO_WARMUP=true


# ------------------------------------------------------------
# OPENROUTER (used by scripts/enrich_toc.py only)
# Not required for normal server operation.
# ------------------------------------------------------------
# OPENROUTER_API_KEY=sk-or-v1-...


# ------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------
# LOG_LEVEL=INFO
# LOG_FILE=/custom/path/to/plesk_unified.log

# LOG_HANDLER selects where logs are sent (stderr is always on, for MCP).
# Options:
#   os    - Native OS handler (default)
#             macOS  → Apple Unified Logging via /var/run/syslog
#                       view: log stream --predicate 'eventMessage CONTAINS "plesk_unified"'
#             Linux  → syslog / journald via /dev/log
#                       view: journalctl -t plesk-unified-mcp --follow
#             Windows → Windows Event Log (requires pywin32)
#                       view: Event Viewer → Windows Logs → Application
#   file  - Rotating file at LOG_FILE path (legacy behaviour)
#   both  - Both native OS handler and file
# LOG_HANDLER=os


# ------------------------------------------------------------
# PATHS (rarely needed)
# Override the knowledge base root directory.
# ------------------------------------------------------------
# KB_ROOT=/custom/path/to/knowledge_base
